# ── App ──────────────────────────────────────────────────────────────────────
APP_URL=https://app.growvoria.com
DEBUG=false
LOG_LEVEL=INFO

# ── Shopify App Credentials (Shopify Partners dashboard) ──────────────────────
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret
SHOPIFY_API_VERSION=2024-10
SHOPIFY_SCOPES=read_products,read_inventory

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (development)
DATABASE_URL=sqlite:///./growvoria_feeds.db
# PostgreSQL (production — uncomment and fill in)
# DATABASE_URL=postgresql://user:password@host:5432/growvoria_feeds

# ── Feed Storage ──────────────────────────────────────────────────────────────
FEEDS_DIR=./feeds

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# ── Scheduler ────────────────────────────────────────────────────────────────
FEED_REFRESH_HOURS=4

# ── Exchange Rates ────────────────────────────────────────────────────────────
EXCHANGE_RATE_TTL=3600
